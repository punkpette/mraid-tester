# Copy this file to .env and fill in real values.
# .env is gitignored; this file is committed as a template.
# All variables must be prefixed with EXPO_PUBLIC_ so Expo injects them
# into process.env at build time.

# App identity
EXPO_PUBLIC_APP_NAME=MRAID Tester
EXPO_PUBLIC_IOS_BUNDLE_ID=com.evolvemedia.mraidtester
EXPO_PUBLIC_ANDROID_PACKAGE=com.evolvemedia.mraidtester

# Google Mobile Ads App IDs (defaults above are Google's official test IDs)
EXPO_PUBLIC_ADMOB_ANDROID_APP_ID=ca-app-pub-3940256099942544~3347511713
EXPO_PUBLIC_ADMOB_IOS_APP_ID=ca-app-pub-3940256099942544~1458002511

# Feature flags
EXPO_PUBLIC_ENABLE_NATIVE_ACTIONS=true
